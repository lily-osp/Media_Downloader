{
  "manifest_version": 3,
  "name": "YT Cookie Sync",
  "version": "1.0",
  "description": "Auto-syncs YouTube cookies to your Media Downloader server",
  "permissions": ["cookies", "storage"],
  "host_permissions": ["https://*.youtube.com/*", "https://*.google.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
